# Database Configuration
# 로컬 SQLite 사용시 아래 값 설정 (기본값)
DB_TYPE=sqlite
DB_PATH=campus_notices.db

# Production Supabase/PostgreSQL 사용시 아래 값 설정
# DB_TYPE=postgresql
# DB_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# AI Summary Webhook Configuration
# 수집된 공지를 타 팀원의 AI 요약 서버에 전달하기 위한 API URL
AI_SUMMARY_WEBHOOK_URL=http://localhost:8000/api/summarize

# Gemini API Configuration (RAG/챗봇 답변 생성)
# 키가 없으면 DB 검색 기반 폴백 응답으로 동작합니다.
GEMINI_API_KEY=

# Vector RAG (pgvector) - Optional
# Supabase(Postgres)에서 pgvector가 활성화되어 있으면 아래를 켜면 유사도 검색을 사용합니다.
# 임베딩 API 호출 비용이 발생할 수 있으니 필요할 때만 사용하세요.
ENABLE_VECTOR_RAG=0
VECTOR_DIM=768
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Crawler & Scheduler Configuration
# 크롤링 주기 (단위: 분)
CRAWL_INTERVAL_MINUTES=60

# Port for crawler management API
API_PORT=8000
API_HOST=0.0.0.0
